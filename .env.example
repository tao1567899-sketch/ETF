# =====================================================================
# 国内ETF智能分析系统 - 环境变量配置（优化版 v2）
# 复制此文件为 .env 并填写你的配置
# =====================================================================

# ── LLM 配置（必填，否则无AI分析） ─────────────────────────────────────────
# 使用 MiniMax（国内可直连，无需代理）
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_API_KEY=your_minimax_api_key_here
LLM_MODEL=MiniMax-Text-01
LLM_MAX_TOKENS=2048

# MiniMax Group ID（部分接口需要）
MINIMAX_GROUP_ID=your_group_id_here

# 备选 DeepSeek：
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ── ETF 列表配置（优化版：宽基+AI科技+红利+黄金+弹性） ───────────────────
# 要分析的ETF代码，逗号分隔（6位数字，无市场前缀）
# 宽基: 510050(上证50) 510300(沪深300) 510500(中证500) 588000(科创50) 159915(创业板)
# AI科技: 512930(AI人工智能) 512480(半导体) 159819(人工智能易方达)
# 红利: 510880(红利) 512890(红利低波)
# 资源: 518880(黄金) 512400(有色金属)
# 弹性: 512880(证券)
ETF_LIST=510050,510300,510500,588000,512930,512480,510880,512890,518880,512400,159915,512880

# ── 数据源配置 ──────────────────────────────────────────────────────────────
DATA_SOURCE=akshare
# 如使用 Tushare（需申请token）：
# DATA_SOURCE=tushare
# TUSHARE_TOKEN=your_tushare_token_here

# ── 推送渠道配置（选填，至少配置一个才会推送） ───────────────────────────────
# 可配置: wecom, dingtalk, feishu, telegram, pushplus, email（多个用逗号分隔）
# 留空则自动检测已配置的渠道
NOTIFY_CHANNELS=

# 推送级别: all=全部推送, strong=仅强信号(strong_buy/strong_sell)推送
NOTIFY_LEVEL=all

# PushPlus 微信推送（推荐个人用户使用，支持 Markdown 格式）
# 注册: https://www.pushplus.plus/ 获取 token
PUSHPLUS_TOKEN=

# 企业微信 Webhook
WECOM_WEBHOOK=

# 钉钉机器人
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 飞书自定义机器人
# 在飞书群设置 → 群机器人 → 添加自定义机器人，获取 Webhook 地址
# 如启用签名校验，填写 FEISHU_SECRET
FEISHU_WEBHOOK=
FEISHU_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件 (SMTP SSL)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_auth_code
SMTP_TO=recipient@example.com

# ── 定时任务配置 ─────────────────────────────────────────────────────────────
# Cron 表达式（默认：周一至周五 16:00 A股收盘后执行）
# 格式: 分 时 日 月 周几(0-7, 1-5=周一至周五)
SCHEDULE_CRON=0 16 * * 1-5
SCHEDULE_TIMEZONE=Asia/Shanghai

# ── 报告配置 ─────────────────────────────────────────────────────────────────
REPORT_DIR=reports
REPORT_LANGUAGE=zh

# ── Web 服务配置 ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
